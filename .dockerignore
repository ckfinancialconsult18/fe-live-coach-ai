# Dependencies (reinstalled in Docker)
node_modules
npm-debug.log*

# Next.js build output (rebuilt in Docker)
.next
out

# Environment secrets — NEVER bake into the image
.env
.env.*
!.env.example

# Development tools
.git
.gitignore
.eslintcache
*.tsbuildinfo

# Editor / OS cruft
.DS_Store
.vscode
.idea
*.swp
*.swo

# Test output
coverage

# Docs (not needed at runtime)
*.md
!README.md
